---
import Layout from '../layouts/Layout.astro';

// DATOS
const TELEFONO_WHATSAPP = "34678846424";
const TELEFONO_VISUAL = "678 84 64 24";
const MENSAJE_DEFAULT = "Hola Manoli, me gustaría encargar un pastel...";

// URLS
const whatsappLink = `https://wa.me/${TELEFONO_WHATSAPP}?text=${MENSAJE_DEFAULT}`;
const telefonoLink = `tel:${TELEFONO_WHATSAPP}`;

const siteUrl = "https://www.xn--manolipastelesdepaales-1ec.com";

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contacto — Manoli Pasteles de Pañales",
  "description": "Contacta con Manoli para encargar tu pastel de pañales artesanal en Badalona. Respuesta por WhatsApp en menos de 24h.",
  "url": `${siteUrl}/contacto/`,
  "mainEntity": {
    "@type": "LocalBusiness",
    "@id": `${siteUrl}/#business`,
    "name": "Manoli Pasteles de Pañales",
    "telephone": "+34678846424"
  }
};
---

<Layout title="Contacto | Encarga tu Pastel de Pañales en Badalona">
  <script type="application/ld+json" set:html={JSON.stringify(contactPageSchema)} />

  <main class="bg-gray-50 min-h-screen">
    
    <section class="bg-white py-16 text-center shadow-sm">
      <div class="container mx-auto px-4">
        <h1 class="text-4xl font-bold text-gray-800 mb-4">Haz tu encargo</h1>
        <p class="text-xl text-gray-500 max-w-2xl mx-auto">
          Hablemos por WhatsApp para diseñar el regalo perfecto. <br>
          <span class="text-sm mt-2 block text-pink-500 font-semibold">Respuesta rápida y trato personal con Manoli.</span>
        </p>
      </div>
    </section>

    <div class="container mx-auto px-4 py-12">
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto mb-12">
        
        <div class="bg-white p-8 rounded-2xl shadow-md hover:shadow-xl transition text-center border-t-4 border-green-500">
          <div class="text-4xl mb-4">💬</div>
          <h3 class="text-xl font-bold text-gray-800 mb-2">WhatsApp</h3>
          <p class="text-gray-500 mb-6 text-sm">Para encargos, dudas y fotos.</p>
          <a href={whatsappLink} target="_blank" class="block w-full bg-green-500 hover:bg-green-600 text-white font-bold py-3 rounded-lg transition shadow-sm hover:shadow-md">
            Enviar Mensaje
          </a>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-md hover:shadow-xl transition text-center border-t-4 border-pink-500">
          <div class="text-4xl mb-4">📞</div>
          <h3 class="text-xl font-bold text-gray-800 mb-2">Llamada</h3>
          <p class="text-gray-500 mb-6 text-sm">Atención directa.</p>
          <a href={telefonoLink} class="block w-full bg-pink-500 hover:bg-pink-600 text-white font-bold py-3 rounded-lg transition shadow-sm hover:shadow-md">
            Llamar al {TELEFONO_VISUAL}
          </a>
        </div>

      </div>

      <div class="text-center max-w-2xl mx-auto">
        <p class="text-gray-500">
          ¿Tienes dudas sobre los pagos o las entregas? 
          <br>
          <a href="/preguntas-frecuentes" class="text-pink-600 font-bold underline hover:text-pink-700 transition">
            Lee las Preguntas Frecuentes aquí
          </a>
        </p>
      </div>

    </div>
  </main>

</Layout>